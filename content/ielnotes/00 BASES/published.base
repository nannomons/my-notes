filters:
  and:
    - publish == true
views:
  - type: table
    name: Table
    order:
      - publish
      - file.name
      - file.folder
      - Course
      - Subject
      - title
    sort:
      - property: file.folder
        direction: ASC
      - property: Course
        direction: ASC
      - property: Subject
        direction: ASC
      - property: Type
        direction: ASC
